# RPC endpoints
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org

# Block explorer
BASESCAN_API_KEY=

# Deployer
DEPLOYER_PRIVATE_KEY=

# Canonical ERC-8004 addresses on Base Sepolia (verify on 8004scan.io before T031)
ERC8004_IDENTITY_ADDRESS=
ERC8004_VALIDATION_ADDRESS=

# Agent operator keys (separate keys per agent — DO NOT reuse deployer)
PROPOSER_OPERATOR_PRIVATE_KEY=
REVIEWER_OPERATOR_PRIVATE_KEY=

# LLM providers — Proposer and Reviewer MUST be different providers
PROPOSER_LLM_PROVIDER=anthropic
PROPOSER_LLM_MODEL=claude-opus-4-7
PROPOSER_LLM_API_KEY=

REVIEWER_LLM_PROVIDER=openai
REVIEWER_LLM_MODEL=gpt-4o
REVIEWER_LLM_API_KEY=

# IPFS pinning (web3.storage / pinata / lighthouse — pick one)
IPFS_PINNING_SERVICE=
IPFS_API_TOKEN=

# Frontend
NEXT_PUBLIC_GATE_ADDRESS=
NEXT_PUBLIC_PROPOSER_AGENT_ID=
NEXT_PUBLIC_REVIEWER_AGENT_ID=
