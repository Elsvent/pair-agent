# RPC endpoints
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org

# Block explorer — single Etherscan V2 key (from https://etherscan.io/myapikey)
# works for Basescan / Arbiscan / Polygonscan / etc. Don't sign up on basescan
# directly any more; the redirect is to etherscan.io for the unified key.
ETHERSCAN_API_KEY=

# Deployer
DEPLOYER_PRIVATE_KEY=

# Canonical ERC-8004 IdentityRegistry on Base Sepolia. Defaults to canonical
# 0x8004A818BFB912233c491871b3d84c89A494BD9e if blank — leave empty unless
# you specifically need to point at a different registry.
ERC8004_IDENTITY_ADDRESS=

# (No ERC8004_VALIDATION_ADDRESS — canonical isn't deployed on Base Sepolia.
#  scripts/deploy.ts deploys our own ValidationRegistryV0 from canonical source.)

# Agent operator keys (separate keys per agent — DO NOT reuse deployer)
PROPOSER_OPERATOR_PRIVATE_KEY=
REVIEWER_OPERATOR_PRIVATE_KEY=

# LLM providers — Proposer and Reviewer MUST be different providers
PROPOSER_LLM_PROVIDER=anthropic
PROPOSER_LLM_MODEL=claude-opus-4-7
PROPOSER_LLM_API_KEY=

REVIEWER_LLM_PROVIDER=openai
REVIEWER_LLM_MODEL=gpt-4o
REVIEWER_LLM_API_KEY=

# IPFS pinning. scripts/mintAgents.ts (T032) reads PINATA_JWT directly.
# For web3.storage instead, set WEB3_STORAGE_TOKEN — TODO: implement that
# branch in scripts/mintAgents.ts (currently throws).
PINATA_JWT=
# Or:
WEB3_STORAGE_TOKEN=

# Frontend
NEXT_PUBLIC_GATE_ADDRESS=
NEXT_PUBLIC_PROPOSER_AGENT_ID=
NEXT_PUBLIC_REVIEWER_AGENT_ID=
